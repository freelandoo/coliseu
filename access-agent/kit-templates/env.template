# ============================================================
#  Coliseu Agent - configuracao (.env)
#  Preencha ANTES da visita; IDFACE_HOST se descobre na academia.
# ============================================================

# Driver do dispositivo: controlid (producao) | fake (teste sem hardware)
ADAPTER=controlid

# URL do CRM na nuvem (sem barra no final). Ex.: https://crm.suaacademia.com.br
BACKEND_URL=

# Token do agente - o MESMO valor configurado como AGENT_TOKEN na nuvem.
# Gere um valor longo e aleatorio (ex.: 64 caracteres hex).
AGENT_TOKEN=

# Id do AccessDevice (copie do dashboard /acesso do CRM)
DEVICE_ID=

# --- Catraca Control iD iDFace (rede local da academia) ---
# IP do aparelho: no iDFace, Menu > Rede. Ex.: 192.168.0.50
IDFACE_HOST=
IDFACE_USER=admin
IDFACE_PASS=

# --- Opcionais (defaults ok para 1 catraca) ---
# IDFACE_RULE_ID=1
# IDFACE_DOOR_ID=1
# INTERVALO_MS=5000
