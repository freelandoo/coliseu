# Asaas (Estágio 2 e 3) — copie para .env.local e preencha
# Sem estas variáveis, o app roda em modo demonstração (cobranças mockadas).
ASAAS_ENV=sandbox                 # sandbox | production
ASAAS_API_KEY=                    # access_token da sua conta Asaas
ASAAS_WEBHOOK_TOKEN=              # token configurado no webhook do Asaas

# Banco (Postgres). Local (fora do docker) usa localhost; dentro do compose use host "db".
DATABASE_URL=postgresql://coliseu:coliseu_dev@localhost:5432/coliseu?schema=public
# Segredo para assinar sessões (gere com: openssl rand -base64 32)
AUTH_SECRET=

# Token compartilhado entre o access-agent e o backend (header x-agent-token)
AGENT_TOKEN=

# Gym Provider API (Freelandoo puxa matricula/catraca/pagamentos)
FREELANDOO_API_TOKEN=

# Piso de alocação de user_id no iDFace. DEVE ser > maior id existente no aparelho
# (inventário de 2026-07-17: maior id = 11097953). Protege contra sequestrar a face
# de um usuário legado não adotado. Ver docs/superpowers/plans/2026-07-16-migracao-cloudgym.md (R1).
ACCESS_EXTERNAL_ID_FLOOR=11097953

# Atendimento WhatsApp (Evolution API). Sem EVOLUTION_URL/EVOLUTION_API_KEY a
# Captacao mostra "WhatsApp nao configurado" e o resto do app segue normal.
# Ver DEPLOY.md -> "Atendimento WhatsApp" para subir evolution-api + redis.
EVOLUTION_URL=http://evolution-api.railway.internal:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=coliseu
# Header x-webhook-secret exigido do webhook da Evolution (obrigatorio em producao)
WHATSAPP_WEBHOOK_SECRET=
# URL publica do app — usada para registrar o webhook na Evolution
PUBLIC_APP_URL=
