# Asaas (Estágio 2 e 3) — copie para .env.local e preencha
# Sem estas variáveis, o app roda em modo demonstração (cobranças mockadas).
ASAAS_ENV=sandbox                 # sandbox | production
ASAAS_API_KEY=                    # access_token da sua conta Asaas
ASAAS_WEBHOOK_TOKEN=              # token configurado no webhook do Asaas

# Banco (Postgres). Local (fora do docker) usa localhost; dentro do compose use host "db".
DATABASE_URL=postgresql://coliseu:coliseu_dev@localhost:5432/coliseu?schema=public
# Segredo para assinar sessões (gere com: openssl rand -base64 32)
AUTH_SECRET=
